# LOOP environment variables
# Copy to loop.env and fill in real values.
# Never commit loop.env to version control.

# Telegram bot token — from @BotFather
LOOP_TELEGRAM_TOKEN=your_telegram_bot_token

# Telnyx API key and public key — from Telnyx console
TELNYX_API_KEY=your_telnyx_api_key
TELNYX_PUBLIC_KEY=your_telnyx_public_key

# OpenRouter API key — for DeepSeek V4 Flash (LLM responses)
OPENROUTER_API_KEY=your_openrouter_api_key

# Public domain for webhook URLs (no trailing slash, no https://)
PUBLIC_DOMAIN=your-domain.com
